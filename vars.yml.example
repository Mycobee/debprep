# debprep configuration
# Copy this file to vars.yml and customize as needed

# Deploy user name (default: deploy)
# This user will be created with sudo access and SSH key authentication
deploy_user: deploy

# Additional apt packages to install
apt_packages:
  - tree
  - curl
  - gnupg

# Firewall rules (UFW)
# SSH is always rate-limited (not allow-listed); set ssh_port if you use a non-standard port
# ssh_port: 22

# Inbound TCP ports to allow
allowed_inbound_tcp_ports:
  - 80    # HTTP
  - 443   # HTTPS

# Inbound UDP ports to allow
allowed_inbound_udp_ports:
  - 443   # QUIC/HTTP3

# Skip firewall configuration entirely
skip_ufw_config: false

# Skip Docker installation
# If false, you'll need to manually add your deploy user to the docker group
install_docker: true
