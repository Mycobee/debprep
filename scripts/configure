#!/bin/bash
set -euo pipefail

DEPLOY_USER=${DEPLOY_USER:-deploy}
VARS_FILE=${VARS_FILE:-vars.yml}

if [[ -z "${DEPLOY_USER_PASSWORD:-}" ]]; then
	echo "Error: DEPLOY_USER_PASSWORD is required" >&2
	exit 1
fi

extra_vars_args=()
if [[ -f "$VARS_FILE" ]]; then
	extra_vars_args=(--extra-vars "@${VARS_FILE}")
fi

ansible-playbook -i inventory.ini ansible/playbooks/configure.yml \
	--extra-vars "ansible_become_password=${DEPLOY_USER_PASSWORD}" \
	--extra-vars "deploy_user=${DEPLOY_USER}" \
	"${extra_vars_args[@]}"
