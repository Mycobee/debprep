#!/bin/bash
set -euo pipefail

usage() {
	cat >&2 <<EOF
Usage: $0 <server_ip> [extra ansible-playbook args...]

Uses your default SSH configuration (~/.ssh/config, ssh-agent).
If \`ssh root@<server_ip>\` works for you, so does this.

Required environment:
  DEPLOY_USER_PASSWORD   Sudo password for the new deploy user. Inject from
                         your secret manager (1Password CLI, Doppler, Vault,
                         shell export, etc.) — not a file on disk.

Optional environment:
  DEPLOY_USER            Name of deploy user to create (default: deploy)
EOF
	exit 1
}

SERVER_IP=${1:-}
[[ -z "$SERVER_IP" ]] && usage
shift

cd "$(dirname "${BASH_SOURCE[0]}")"

DEPLOY_USER=${DEPLOY_USER:-deploy}

if [[ -z "${DEPLOY_USER_PASSWORD:-}" ]]; then
	echo "Error: DEPLOY_USER_PASSWORD is required in the environment" >&2
	exit 1
fi

# Skip SSH host-key verification: a brand-new VPS has no prior known_hosts entry,
# so there's nothing to verify against and the default prompt would block automation.
export ANSIBLE_HOST_KEY_CHECKING=False

common_args=(
	-i "${SERVER_IP},"
	-e "deploy_user=${DEPLOY_USER}"
	-e "ansible_become_password=${DEPLOY_USER_PASSWORD}"
)

echo "==> init playbook"
ansible-playbook "${common_args[@]}" ansible/playbooks/init.yml "$@"

echo "==> configure playbook"
ansible-playbook "${common_args[@]}" ansible/playbooks/configure.yml "$@"
